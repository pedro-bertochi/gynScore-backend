# ─── Configurações da Aplicação ──────────────────────────────────────────────
APP_PORT=3000
APP_ENV=development

# ─── Configurações do Banco de Dados MySQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=gymscore

# ─── Configurações de Autenticação JWT ───────────────────────────────────────
# IMPORTANTE: Altere este valor para uma chave secreta forte em produção
JWT_SECRET=gymscore_mude_esta_chave_em_producao_para_algo_seguro

# ─── Configurações do PIX (Recebedor Sistema) ───────────────────────────────
PIX_CHAVE=sua-chave-pix-aqui@email.com
PIX_NOME_RECEBEDOR=GYMSCORE SISTEMA
PIX_CIDADE_RECEBEDOR=SAO PAULO

# ─── Configurações Asaas (Gateway PIX) ──────────────────────────────────────
ASAAS_API_KEY=seu_token_aqui
ASAAS_BASE_URL=https://sandbox.asaas.com/api
